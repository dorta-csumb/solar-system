<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
</head>
<body>
    <%- include('partials/nav') %>

    <!-- Main Content: Planet Information -->
    <div class="container mt-5">
        <!-- Planet Name/Heading -->
        <h2 class="text-center mb-4 display-4 text-primary"><%= planetName %></h2>
        
        <!-- 2-COLUMN LAYOUT -->
        <div class="row align-items-center">
            
            <!-- Column 1: Image -->
            <div class="col-md-6 text-center">
                <img src="<%= planetData.image %>" alt="Image of <%= planetName %>" class="img-fluid custom-img mb-4">
            </div>
            
            <!-- Column 2: Data & Description -->
            <div class="col-md-6">
                <div class="card p-4 custom-card">
                    <h4 class="text-info border-bottom pb-2">Description</h4>
                    <p><%= planetData.description %></p>
                    
                    <h4 class="text-info border-bottom pb-2 mt-3">Quick Facts</h4>
                    <ul class="list-group list-group-flush">
                        <% if (planetData.distanceFromSun) { %>
                            <li class="list-group-item"><strong>Distance from Sun:</strong> <%= planetData.distanceFromSun %></li>
                        <% } %>
                        <% if (planetData.yearLength) { %>
                            <li class="list-group-item"><strong>Year Length:</strong> <%= planetData.yearLength %></li>
                        <% } %>
                        <% if (planetData.radius) { %>
                            <li class="list-group-item"><strong>Radius:</strong> <%= planetData.radius %></li>
                        <% } %>
                        <% if (planetData.moons !== undefined) { %>
                            <li class="list-group-item"><strong>Moons:</strong> <%= planetData.moons %></li>
                        <% } %>
                    </ul>
                </div>
            </div>

        </div>
    </div>

    <%- include('partials/footer') %>
</body>
</html>
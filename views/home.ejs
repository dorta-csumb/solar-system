<!DOCTYPE html>
<html lang="en">
<head>
    <!-- EJS attaches the head partial -->
    <%- include('partials/head') %>
</head>
<body>
    
    <!-- EJS attaches the nav partial -->
    <%- include('partials/nav') %>

    <div class="container text-center mt-5">
        <h2>Welcome to the Solar System!</h2>
        <p>Enjoy this random view of our cosmic neighborhood.</p>
        
        <!-- Rubric: "random Solar System image is displayed". 
             This grabs the imageURL variable we passed from index.mjs! -->
        <% if (imageURL) { %>
            <img src="<%= imageURL %>" alt="Random Solar System Image" class="img-fluid rounded shadow mt-3" style="max-height: 500px;">
        <% } else { %>
            <p class="text-danger">Image could not be loaded at this time.</p>
        <% } %>
    </div>

    <!-- EJS attaches the footer partial -->
    <%- include('partials/footer') %>

</body>
</html>
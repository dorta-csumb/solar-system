<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
</head>
<body>
    <%- include('partials/nav') %>

    <div class="container mt-5">
        <h2 class="text-center mb-4 text-primary">NASA Picture of the Day</h2>
        <h3 class="text-center mb-4 text-secondary">One small step for man, one giant leap for mankind</h3>
        
        <% if (podData) { %>
            <div class="row justify-content-center">
                <div class="col-md-10 text-center">
                    <h3><%= podData.title %></h3>
                    <p class="text-muted"><%= podData.date %></p>
                    
                    <!-- When NASA posts video instead of an image, this handles both! -->
                    <% if (podData.media_type === 'video') { %>
                        <div class="ratio ratio-16x9 my-4 shadow custom-img">
                            <iframe src="<%= podData.url %>" allowfullscreen></iframe>
                        </div>
                    <% } else { %>
                        <img src="<%= podData.url %>" alt="<%= podData.title %>" class="img-fluid my-4 custom-img">
                    <% } %>
                    
                    <div class="card p-4 text-start custom-card mt-3">
                        <p class="lead"><%= podData.explanation %></p>
                    </div>
                </div>
            </div>
        <% } else { %>
            <h4 class="text-danger text-center">Houston we have a problem. Could not load the Picture of the Day. Please try again later.</h4>
        <% } %>
    </div>

    <%- include('partials/footer') %>
</body>
</html>